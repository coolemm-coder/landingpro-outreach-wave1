{
  "trailingSlash": false,
  "rewrites": [
    { "source": "/mockups/esquire", "destination": "/mockups/esquire.html" },
    { "source": "/mockups/now", "destination": "/mockups/now.html" },
    { "source": "/mockups/beauty-family", "destination": "/mockups/beauty-family.html" },
    { "source": "/mockups/:slug", "destination": "/app.html?slug=:slug" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    }
  ]
}
